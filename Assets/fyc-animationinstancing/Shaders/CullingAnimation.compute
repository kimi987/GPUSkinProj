// #pragma kernel CSCulling
#pragma kernel CSCullingAndAnimation

#include "ShaderLibs/Matrix.hlsl"

#define PositiveInfinity (1.0f / 0.0f)

struct AnimationSaveData
{
    int AnimationNameHash;
    int AnimationIndex;
    int AnimationTexIndex;
    int TotalFrame;
    int Fps;
    bool RootMotion;
    int WrapMode;
};

struct FrameData
{
    int Enable;
    int Pause;
    float AniSpeed;
    int PreAniIndex;
    int CurAniIndex;
    float FrameIndex;
    float PreFrameIndex;
    float TransitionProgress;
    float TransitionDuration;
    int ResetAniIndex;
};

struct MotionData
{
    int enable;
    int Visible;
    int IsCull;
    uint LayerMask;
    int ParentIndex;
    float3 Position;
    float3 Rotation;
    float Scale;
    float MoveSpeed;
    float3 MoveDirection;
    float3 TargetPos;
    float RotateYSpeedSetting;
    float RotateYSpeed;
    float RotateYTarget;
    float RotateYFinal;
    int CurPathIndex;
    int PathIndex;

    // float DebugFinalY;
};

struct DrawFrameData
{
    float4x4 WorldMatrix;
    float FrameIndex;
    float PreFrameIndex;
    float TransitionProgress;
    float Padding;
};

StructuredBuffer<AnimationSaveData> _InfoData;
RWStructuredBuffer<FrameData>  _FrameData;
RWStructuredBuffer<MotionData> _MotionData;
StructuredBuffer<MotionData> _ParentMotionData;
StructuredBuffer<float3> _PathAry;

AppendStructuredBuffer<FrameData> _OutFrameData;
AppendStructuredBuffer<DrawFrameData> _OutDrawFrameData;
float4 _Planes[6]; //Camera Planes
float _DeltaTime;
uint _LayerMask;
int _CullingType;
uint _InstanceCount;

